<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2026 Antonio Zugaldia -->
<component type="desktop-application">
    <id>io.speedofsound.SpeedOfSound</id>
    <name>Speed of Sound</name>
    <summary>Voice typing for the Linux desktop</summary>
    <metadata_license>MIT</metadata_license>
    <project_license>MIT</project_license>
    <description>
        <p>
            Speed of Sound is a voice-typing app for the Linux desktop.
        </p>
        <p>
            By default, transcription runs entirely on-device, so no audio ever leaves your machine.
            The app ships with a built-in multilingual Whisper model and supports additional models from the
            Whisper, Parakeet, and Canary families to improve accuracy.
        </p>
        <ul>
            <li>Offline, private transcription with popular open speech models (Whisper, Parakeet, Canary)</li>
            <li>Multiple activation options: click the in-app button or use a global keyboard shortcut</li>
            <li>Types directly into any app via XDG Desktop Portals (supports X11 and Wayland)</li>
            <li>Optional text polishing with LLMs, supports self-hosted services like Ollama, vLLM, and llama.cpp</li>
            <li>Optional cloud providers supported for resource-constrained hardware environments</li>
        </ul>
        <p>Please visit speedofsound.io/getting-started after installation.</p>
    </description>

    <url type="homepage">https://www.speedofsound.io</url>
    <url type="faq">https://www.speedofsound.io/faq</url>
    <url type="help">https://www.speedofsound.io/support</url>
    <url type="vcs-browser">https://github.com/zugaldia/speedofsound</url>
    <url type="bugtracker">https://github.com/zugaldia/speedofsound/issues</url>
    <url type="contribute">https://github.com/zugaldia/speedofsound/blob/main/README.md</url>
    <url type="donation">https://github.com/sponsors/zugaldia</url>

    <url type="contact">https://www.zugaldia.com</url>
    <developer id="com.zugaldia">
        <name>Antonio Zugaldia</name>
    </developer>

    <content_rating type="oars-1.1" />
    <launchable type="desktop-id">io.speedofsound.SpeedOfSound.desktop</launchable>

    <screenshots>
        <screenshot type="default">
            <caption>Voice typing into the default text editor</caption>
            <image>https://www.speedofsound.io/assets/screenshots/demo-light.png</image>
        </screenshot>
        <screenshot>
            <caption>The model library</caption>
            <image>https://www.speedofsound.io/assets/screenshots/preferences-light.png</image>
        </screenshot>
        <screenshot>
            <caption>Add personal context and custom words to improve accuracy</caption>
            <image>https://www.speedofsound.io/assets/screenshots/preferences-personalization-light.png</image>
        </screenshot>
    </screenshots>

    <releases>
        <release version="0.14.0" date="2026-05-09">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.14.0</url>
            <description>
                <p>
                    Added clipboard output as an alternative to keyboard simulation — useful when
                    the XDG Remote Desktop Portal is unavailable or restricted. Tap the language
                    label in the main window to quickly toggle between your primary and secondary
                    language without opening Preferences. Updated the Gradle wrapper to 9.4.1 to
                    match the Flatpak SDK extension.
                </p>
            </description>
        </release>
        <release version="0.13.0" date="2026-04-21">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.13.0</url>
            <description>
                <p>
                    Added a system tray icon with Start/Stop Listening, Open App, and Quit
                    actions for quick control without opening the main window. New Disable
                    Thinking option for LLM text providers reduces latency and cost on models
                    that support reasoning, and a Test Connection button lets you verify
                    credentials before saving. Fixed the app auto-quitting after a few seconds
                    when "Stay hidden on activation" was enabled. Fixed a native resource leak
                    where the Sherpa ONNX stream was not released on transcription failure.
                    Updated Java-GI to 0.15.0 and Stargate to 0.5.0.
                </p>
            </description>
        </release>
        <release version="0.12.0" date="2026-04-11">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.12.0</url>
            <description>
                <p>
                    Added support for NVIDIA Canary and Parakeet ASR model families alongside
                    Whisper, giving more options for on-device speech recognition across multiple
                    languages. New "Stay hidden on activation" setting lets you add the app to
                    system startup without showing the main window. The app now detects when the
                    XDG Remote Desktop Portal is not supported and shows a clear banner instead
                    of failing silently. Fixed typing error propagation so non-Latin script
                    failures surface as notifications instead of being swallowed. Fixed a bug
                    where changing the secondary language in Preferences didn't update the main
                    window. Updated dependencies including Sherpa ONNX, Kotlin, and cloud SDKs.
                </p>
            </description>
        </release>
        <release version="0.11.0" date="2026-03-29">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.11.0</url>
            <description>
                <p>
                    Added Start and Stop buttons to the main window for easier control without a
                    keyboard shortcut. Fixed Unicode and CJK character support so text in Arabic,
                    Chinese, Japanese, Korean, and other non-Latin scripts now types correctly.
                    The app now exits immediately with a clear error on fatal startup failures
                    instead of hanging silently. Icons are now bundled as compiled GLib resources
                    for reliable display across all distribution formats.
                </p>
            </description>
        </release>
        <release version="0.10.1" date="2026-03-25">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.10.1</url>
            <description>
                <p>
                    Fixed a bug where the built-in Tiny model was unavailable in the Snap package
                    due to Git LFS files not being fetched during the build. Also adds a direct
                    download link for the keyboard shortcut helper script in the setup guide.
                </p>
            </description>
        </release>
        <release version="0.10.0" date="2026-03-25">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.10.0</url>
            <description>
                <p>
                    Improved the welcome carousel with per-page images and cleaner copy; keyboard
                    shortcut keys are now displayed in monospace throughout the UI. The shortcut
                    setup link in Preferences now opens directly to the keyboard shortcut
                    documentation page. Updated Flatpak to target the GNOME 50 runtime. Fixed a
                    confusing crash for developers cloning the repo without Git LFS by detecting
                    LFS pointer files and surfacing a clear error message.
                </p>
            </description>
        </release>
        <release version="0.9.0" date="2026-03-22">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.9.0</url>
            <description>
                <p>
                    Added global keyboard shortcuts: set up a system-wide shortcut (Super+Z by default)
                    to trigger recording from any application, with a guided setup flow in Preferences.
                    New first-launch welcome carousel walks new users through permissions, shortcut setup,
                    and getting started. Redesigned main window with a proper GNOME header bar — the menu
                    is now in the top-right and native minimize/close buttons are visible. Added desktop
                    notifications for pipeline errors and typing failures so issues are no longer silent.
                    Added a Help menu item linking to the documentation. New distribution formats: AppImage,
                    DEB, and RPM packages are now available alongside Flatpak and Snap. Fixed WAV and
                    model staging files to use the XDG cache directory instead of the data directory.
                    Fixed dropdown search in the language and model selectors. Updated Anthropic, Google,
                    and OpenAI SDKs with latest model support.
                </p>
            </description>
        </release>
        <release version="0.8.0" date="2026-03-11">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.8.0</url>
            <description>
                <p>
                    The app now starts faster with async plugin initialization — the main window
                    appears immediately with a loading indicator while models and services initialize
                    in the background. Added an Advanced preferences page with configurable typing
                    delay settings. Added General preferences for appending a space after each
                    transcription and a background recording mode that types results directly into
                    the target app without showing the main window. Improved LLM text polishing to
                    prefer digits and symbols over spelled-out words (e.g. "2" instead of "two").
                    Fixed Flatpak and Snap packaging issues and addressed Flathub store review feedback.
                </p>
            </description>
        </release>
        <release version="0.7.0" date="2026-03-06">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.7.0</url>
            <description>
                <p>
                    Added Flatpak and Snap distribution packages with proper desktop integration
                    (icons, desktop entry, AppStream metadata, D-Bus activation). Fixed a bug where
                    bare S and M key presses would trigger spurious recording cycles when the window
                    still had focus after typing — now requires Ctrl+S and Ctrl+M. Added GPT 5.4
                    support and updated all dependencies.
                </p>
            </description>
        </release>
        <release version="0.6.0" date="2026-03-04">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.6.0</url>
            <description>
                <p>
                    Added Gemini 3.1 Pro and Gemini Flash Lite as available cloud text models,
                    replacing Gemini 3 Pro. Also improved LLM text polishing quality with
                    few-shot prompt examples for better handling of commonly spoken language patterns.
                    Fixed icon visibility for model removal on light mode.
                </p>
            </description>
        </release>
        <release version="0.5.0" date="2026-02-24">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.5.0</url>
            <description>
                <p>
                    New Import/Export page in Preferences lets you back up your full configuration
                    (API keys, LLM providers, vocabulary, and language settings) to a JSON file and
                    restore it on any machine. Also improved the LLM text polishing prompt with better
                    handling of capitalization, punctuation, and spoken abbreviations.
                </p>
            </description>
        </release>
        <release version="0.4.0" date="2026-02-23">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.4.0</url>
            <description>
                <p>
                    Fixed two crashes: one on startup caused by a threading issue in the main view,
                    and one during shutdown in the audio pipeline. When a previously configured ASR
                    model is no longer available, the app now automatically falls back to the default
                    Whisper model instead of crashing. Built-in models no longer show a delete button
                    in the Voice Models preferences page.
                </p>
            </description>
        </release>
        <release version="0.3.0" date="2026-02-22">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.3.0</url>
            <description>
                <p>
                    Lowered the minimum required JDK from 25 to 22, making the app easier to run on
                    more systems without needing a bleeding-edge Java installation.
                </p>
            </description>
        </release>
        <release version="0.2.0" date="2026-02-22">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.2.0</url>
            <description>
                <p>
                    Fixed a crash on fresh installations where no ASR model had been configured yet.
                    The app now falls back to the default Whisper model automatically on the first run.
                    Also expanded the FAQ with coverage of privacy, microphone selection, model sizes,
                    and Wayland/X11 compatibility.
                </p>
            </description>
        </release>
        <release version="0.1.0" date="2026-02-22">
            <url type="details">https://github.com/zugaldia/speedofsound/releases/tag/v0.1.0</url>
            <description>
                <p>
                    First release of Speed of Sound. Captures microphone audio, transcribes it
                    on-device using Whisper via Sherpa ONNX, and types the result into any focused
                    application using XDG Desktop Portal keyboard simulation. Optional LLM text
                    polishing is supported via Anthropic, Google, OpenAI, and compatible self-hosted
                    endpoints such as Ollama, vLLM, and llama.cpp.
                </p>
            </description>
        </release>
    </releases>
</component>
